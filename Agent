<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Annie Rause — Dalton Wade Real Estate Group | Gulf Coast</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1B2A4A;
    --navy-mid: #2A3D6B;
    --purple: #4A3570;
    --purple-light: #7B5EA7;
    --pink: #E8729A;
    --pink-light: #F2A0BB;
    --blush: #FAD4E0;
    --orange: #F5A04A;
    --gold: #F0C060;
    --gold-light: #FAE0A8;
    --cream: #FDF8F2;
    --cream-dark: #F0E8DC;
    --text-dark: #1B2A4A;
    --text-mid: #4A4060;
    --text-light: #9A90B0;
    --white: #FFFFFF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Jost', sans-serif; background: var(--white); color: var(--text-dark); }

  /* ── TOP BAR ── */
  .top-bar {
    background: linear-gradient(135deg, var(--orange), var(--pink));
    padding: 10px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .top-bar-text {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: white;
    font-weight: 300;
  }

  .top-bar-text strong { font-weight: 600; }

  .top-bar-btn {
    background: white;
    color: var(--pink);
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    transition: transform 0.2s;
  }
  .top-bar-btn:hover { transform: scale(1.03); }

  /* ── NAV ── */
  .site-nav {
    background: var(--navy);
    padding: 0 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 24px rgba(27,42,74,0.25);
  }

  .nav-brand {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    color: white;
    letter-spacing: 2px;
    line-height: 1;
  }

  .nav-brand-sub {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 300;
    line-height: 1;
  }

  .site-nav-links {
    display: flex;
    gap: 28px;
    list-style: none;
    align-items: center;
  }

  .site-nav-links a {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }
  .site-nav-links a:hover { color: var(--gold); }

  .nav-cta {
    background: linear-gradient(135deg, var(--orange), var(--pink)) !important;
    color: white !important;
    padding: 10px 22px !important;
    border-radius: 6px !important;
    font-weight: 500 !important;
  }

  .nav-pm {
    background: rgba(255,255,255,0.08) !important;
    color: rgba(255,255,255,0.7) !important;
    padding: 10px 18px !important;
    border-radius: 6px !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    font-size: 10px !important;
  }
  .nav-pm:hover { background: rgba(255,255,255,0.15) !important; color: white !important; }

  /* ── HERO ── */
  .site-hero {
    background: linear-gradient(160deg, var(--navy) 0%, var(--purple) 40%, #2A1845 100%);
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 80px 60px;
    position: relative;
    overflow: hidden;
  }

  .site-hero::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(240,192,96,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .site-hero::after {
    content: '';
    position: absolute;
    bottom: -80px; left: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,114,154,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    max-width: 1040px;
    margin: 0 auto;
    width: 100%;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-content { max-width: 580px; }

  .hero-eyebrow {
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 300;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before { content: ''; width: 30px; height: 1px; background: var(--gold); }

  .hero-h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 62px;
    font-weight: 700;
    color: white;
    line-height: 1.05;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }

  .hero-h1 em {
    font-style: italic;
    font-weight: 400;
    background: linear-gradient(135deg, var(--gold), var(--pink-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-p {
    font-size: 16px;
    font-weight: 300;
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    margin-bottom: 36px;
    max-width: 500px;
  }

  .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }

  .btn-primary {
    background: linear-gradient(135deg, var(--orange), var(--pink));
    color: white;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 500;
    padding: 16px 32px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(245,160,74,0.3);
    text-decoration: none;
    display: inline-block;
  }

  .btn-secondary {
    background: transparent;
    color: rgba(255,255,255,0.7);
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 300;
    padding: 16px 32px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .hero-stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
    padding-top: 36px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat-item { display: flex; flex-direction: column; }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 700; color: var(--gold); line-height: 1; }
  .stat-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); font-weight: 300; margin-top: 4px; }

  /* Agent photo in hero */
  .hero-agent {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .hero-agent-img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 4px solid rgba(240,192,96,0.35);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .hero-agent-badge {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 14px 20px;
    text-align: center;
    width: 210px;
  }

  .hab-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 700;
    color: white;
    margin-bottom: 3px;
  }

  .hab-title {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 300;
    line-height: 1.5;
  }

  /* ── SECTION SHARED ── */
  .section-eyebrow { font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--orange); font-weight: 300; text-align: center; margin-bottom: 12px; }
  .section-h2 { font-family: 'Cormorant Garamond', serif; font-size: 46px; font-weight: 600; color: var(--navy); text-align: center; line-height: 1.2; margin-bottom: 16px; }
  .section-h2 em { font-style: italic; color: var(--purple-light); }
  .section-sub { text-align: center; font-size: 15px; font-weight: 300; color: var(--text-mid); max-width: 560px; margin: 0 auto 64px; line-height: 1.7; }

  /* ── SERVICES ── */
  .site-services { padding: 100px 60px; background: var(--cream); }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    max-width: 1040px;
    margin: 0 auto;
  }

  .svc-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(27,42,74,0.08);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .svc-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(27,42,74,0.14); }

  .svc-top { padding: 36px 28px 24px; }
  .svc-icon { width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 20px; }
  .svc-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 700; color: var(--navy); margin-bottom: 10px; line-height: 1.2; }
  .svc-desc { font-size: 13px; font-weight: 300; color: var(--text-mid); line-height: 1.7; margin-bottom: 18px; }
  .svc-list { list-style: none; display: flex; flex-direction: column; gap: 7px; }
  .svc-list li { font-size: 12px; font-weight: 300; color: var(--text-mid); display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; }
  .svc-list li::before { font-weight: 600; font-size: 11px; flex-shrink: 0; margin-top: 1px; }
  .svc-footer { padding: 18px 28px; display: flex; align-items: center; justify-content: space-between; }
  .svc-link { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; font-weight: 500; text-decoration: none; }

  .svc-buyer .svc-icon { background: linear-gradient(135deg, #FFF0D0, #FFE0B0); }
  .svc-buyer .svc-list li::before { content: '✓'; color: var(--orange); }
  .svc-buyer .svc-footer { background: linear-gradient(135deg, #FFF8EE, #FFF0D8); }
  .svc-buyer .svc-link { color: var(--orange); }

  .svc-seller .svc-icon { background: linear-gradient(135deg, #F0E8FF, #E4D5FF); }
  .svc-seller .svc-list li::before { content: '✓'; color: var(--purple-light); }
  .svc-seller .svc-footer { background: linear-gradient(135deg, #F8F4FF, #F0E8FF); }
  .svc-seller .svc-link { color: var(--purple-light); }

  .svc-invest .svc-icon { background: linear-gradient(135deg, #FFE8F0, #FFD5E5); }
  .svc-invest .svc-list li::before { content: '✓'; color: var(--pink); }
  .svc-invest .svc-footer { background: linear-gradient(135deg, #FFF5F8, #FFE8F0); }
  .svc-invest .svc-link { color: var(--pink); }

  /* ── AREAS ── */
  .site-areas { padding: 100px 60px; background: white; }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1040px;
    margin: 0 auto;
  }

  .area-card {
    background: var(--cream);
    border-radius: 16px;
    padding: 32px 20px;
    text-align: center;
    border: 1px solid var(--cream-dark);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .area-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(27,42,74,0.1); background: white; }
  .area-icon { font-size: 32px; margin-bottom: 14px; display: block; }
  .area-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .area-desc { font-size: 12px; font-weight: 300; color: var(--text-mid); line-height: 1.6; }

  /* ── ABOUT ── */
  .site-about {
    padding: 100px 60px;
    background: linear-gradient(160deg, var(--navy) 0%, var(--purple) 100%);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 80px;
    max-width: 1040px;
    margin: 0 auto;
    align-items: center;
  }

  .about-img-wrap { display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .about-img { width: 240px; height: 240px; border-radius: 50%; object-fit: cover; object-position: center top; border: 4px solid rgba(240,192,96,0.4); box-shadow: 0 20px 60px rgba(0,0,0,0.3); }

  .about-badge { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 16px 20px; text-align: center; width: 100%; }
  .about-badge-name { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 700; color: white; margin-bottom: 4px; }
  .about-badge-brokerage { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); font-weight: 400; margin-bottom: 2px; }
  .about-badge-title { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.45); font-weight: 300; }

  .about-right h2 { font-family: 'Cormorant Garamond', serif; font-size: 44px; font-weight: 600; color: white; line-height: 1.2; margin-bottom: 20px; }
  .about-right h2 em { font-style: italic; color: var(--gold); }
  .about-bio { font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.75); line-height: 1.9; margin-bottom: 32px; }

  .about-points { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .about-point { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px 18px; display: flex; align-items: flex-start; gap: 12px; }
  .about-point-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
  .about-point-text { font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .about-point-text strong { color: white; font-weight: 500; display: block; margin-bottom: 2px; font-size: 13px; }

  /* ── CONTACT ── */
  .site-contact { padding: 100px 60px; background: var(--cream); }
  .contact-inner { max-width: 720px; margin: 0 auto; text-align: center; }

  .contact-card { background: white; border-radius: 24px; padding: 56px; box-shadow: 0 24px 72px rgba(27,42,74,0.1); margin-top: 48px; }

  .contact-annie-wrap { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 8px; }
  .contact-annie-img { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; object-position: center top; border: 3px solid rgba(245,160,74,0.5); flex-shrink: 0; }
  .contact-name { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 700; color: var(--navy); }
  .contact-title-text { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--orange); font-weight: 300; margin-bottom: 32px; display: block; }

  .contact-items { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; margin-bottom: 36px; }
  .contact-item { display: flex; flex-direction: column; align-items: center; gap: 5px; }
  .ci-label { font-size: 8px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-light); font-weight: 400; }
  .ci-value { font-size: 15px; font-weight: 400; color: var(--navy); }

  .contact-form { display: flex; flex-direction: column; gap: 14px; margin-top: 32px; text-align: left; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field label { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-light); font-weight: 400; }
  .form-field input, .form-field textarea, .form-field select {
    border: 1px solid var(--cream-dark); border-radius: 8px; padding: 12px 16px;
    font-family: 'Jost', sans-serif; font-size: 13px; font-weight: 300;
    color: var(--text-dark); background: var(--cream); outline: none; transition: border-color 0.2s;
  }
  .form-field input:focus, .form-field textarea:focus, .form-field select:focus { border-color: var(--purple-light); }
  .form-field textarea { resize: vertical; min-height: 100px; }

  .form-submit {
    background: linear-gradient(135deg, var(--navy), var(--purple));
    color: white; font-family: 'Jost', sans-serif; font-size: 11px; letter-spacing: 3px;
    text-transform: uppercase; font-weight: 500; padding: 16px 40px; border-radius: 8px;
    border: none; cursor: pointer; box-shadow: 0 8px 24px rgba(27,42,74,0.2); align-self: center; margin-top: 8px;
  }

  /* ── FOOTER ── */
  .site-footer { background: var(--navy); padding: 40px 60px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .footer-brand { display: flex; flex-direction: column; gap: 4px; }
  .footer-brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 700; color: white; letter-spacing: 2px; }
  .footer-brand-sub { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); font-weight: 300; }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
  .footer-links a { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none; font-weight: 300; }
  .footer-links a:hover { color: var(--gold); }
  .footer-copy { font-size: 10px; letter-spacing: 1px; color: rgba(255,255,255,0.25); font-weight: 300; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  .hero-content > * { animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) both; }
  .hero-content > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-content > *:nth-child(2) { animation-delay: 0.2s; }
  .hero-content > *:nth-child(3) { animation-delay: 0.3s; }
  .hero-content > *:nth-child(4) { animation-delay: 0.4s; }
  .hero-content > *:nth-child(5) { animation-delay: 0.5s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .top-bar { padding: 10px 20px; }
    .site-nav { padding: 0 24px; }
    .site-nav-links { display: none; }
    .site-hero { padding: 60px 28px; min-height: auto; }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-agent { display: none; }
    .hero-h1 { font-size: 44px; }
    .site-services, .site-areas, .site-about, .site-contact { padding: 72px 28px; }
    .services-grid { grid-template-columns: 1fr; }
    .areas-grid { grid-template-columns: 1fr 1fr; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-points { grid-template-columns: 1fr; }
    .contact-card { padding: 36px 24px; }
    .form-row { grid-template-columns: 1fr; }
    .contact-items { gap: 24px; }
    .site-footer { padding: 32px 28px; flex-direction: column; align-items: flex-start; }
    .section-h2 { font-size: 36px; }
  }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <span class="top-bar-text"><strong>Sol Tide Properties LLC</strong> &nbsp;·&nbsp; Gulf Coast Property Management & Home Watch</span>
  <a href="soltide.html" class="top-bar-btn">Property Management →</a>
</div>

<!-- NAV -->
<nav class="site-nav">
  <div class="nav-brand">
    <div class="nav-brand-name">Annie Rause</div>
    <div class="nav-brand-sub">Dalton Wade Real Estate Group</div>
  </div>
  <ul class="site-nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#areas">Areas</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="soltide.html" class="nav-pm">Sol Tide PM</a></li>
    <li><a href="#contact" class="nav-cta">Start Here</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="site-hero" id="home">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow">Gulf Coast Real Estate · Dalton Wade</div>
      <h1 class="hero-h1">Your Gulf Coast<br>Home Starts <em>Here.</em></h1>
      <p class="hero-p">Annie Rause is a licensed Gulf Coast real estate agent with Dalton Wade Real Estate Group — bringing 4+ years of investing and market expertise to every buyer, seller, and investor she works with.</p>
      <div class="hero-btns">
        <a href="#contact" class="btn-primary">Start Here</a>
        <a href="#services" class="btn-secondary">View Services</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-num">4+</span>
          <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">FL</span>
